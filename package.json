{
	"preferGlobal": true,
	"name": "@derhuerst/technical-docs-cli",
	"description": "Render technical markdown docs as HTML. Opinionated.",
	"version": "1.5.0",
	"bin": {
		"build-technical-doc": "./cli.js"
	},
	"type": "module",
	"main": "index.js",
	"files": [
		"cli.js",
		"index.js",
		"lib"
	],
	"keywords": [
		"markdown",
		"render",
		"html",
		"docs",
		"documentation",
		"cli"
	],
	"author": "Jannis R <mail@jannisr.de>",
	"homepage": "https://github.com/derhuerst/technical-docs-cli",
	"repository": "derhuerst/technical-docs-cli",
	"bugs": "https://github.com/derhuerst/technical-docs-cli/issues",
	"license": "ISC",
	"engines": {
		"node": ">=24"
	},
	"dependencies": {
		"hast-util-select": "^6.0.4",
		"hast-util-to-text": "^4.0.2",
		"hastscript": "^9.0.1",
		"highlight.js": "^11.11.1",
		"mri": "^1.1.6",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-github-alerts": "^4.2.0",
		"rehype-highlight": "^7.0.2",
		"rehype-raw": "^7.0.0",
		"rehype-slug": "^6.0.0",
		"rehype-stringify": "^10.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"unified": "^11.0.5",
		"unified-stream": "^3.0.0",
		"unist-builder": "^4.0.0",
		"unist-util-select": "^5.1.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"eslint": "^10.3.0",
		"globals": "^17.6.0"
	},
	"scripts": {
		"lint": "eslint .",
		"test": "node test.js",
		"test-example": "./cli.js <example.md >/dev/null",
		"prepublishOnly": "npm run lint && npm test && npm run test-example"
	}
}
